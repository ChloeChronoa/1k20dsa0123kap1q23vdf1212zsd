    if decided then return end
    decided = true
    gui:Destroy()
    loadSupportedGame()
end)

monitorButton.Activated:Connect(function()
    if decided then return end
    monitorButton.Text = "Connecting..."
    statusLabel.Text = "Looking for Chloe X Monitor on this device..."
    local ok, result = startMonitor()
    if not ok then
        monitorButton.Text = "Try Again"
        statusLabel.Text = result
        notify("Chloe X Monitor", result, 6)
        return
    end
    decided = true
    statusLabel.TextColor3 = Color3.fromRGB(70, 229, 173)
    statusLabel.Text = "Secret-Key Successfully Copied! "
    monitorButton.Text = "Connected"
    task.wait(0.65)
    gui:Destroy()
    loadSupportedGame()
end)
