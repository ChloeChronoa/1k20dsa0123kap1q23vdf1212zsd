-- Chloe X supported-game loader with an optional local Monitor connection.

local games = {
    [10200395747] = "https://raw.githubusercontent.com/ChloeChronoa/21a0270b7f66a1e4c25933f13a1e5a1bbb4757578072930c8189131f9c6aaae1/refs/heads/main/95307755f3d4cdad72529801af83637b9b458c89a073c651f6c01b0b9f38ea62",
}

local CoreGui = game:GetService("CoreGui")
local StarterGui = game:GetService("StarterGui")
local environment = (getgenv and getgenv()) or _G
local gameUrl = games[game.GameId]

local function notify(title, text, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", { Title = title, Text = text, Duration = duration or 5 })
    end)
end

if not gameUrl then
    notify("Chloe Notification", "Unsupported game. Sorry....", 5)
    return
end

local function loadSupportedGame()
    notify("Chloe Notification", "Supported game! Loading....", 5)
    local ok, source = pcall(game.HttpGet, game, gameUrl)
    if not ok then
        notify("Chloe Loader", "Failed to download the game script.", 7)
        warn("[CHX Loader] " .. tostring(source))
        return false
    end
    local chunk, compileError = loadstring(source)
    if not chunk then
        notify("Chloe Loader", "The game script could not be compiled.", 7)
        warn("[CHX Loader] " .. tostring(compileError))
        return false
    end
    task.spawn(chunk)
    return true
end

local requestFn =
    (type(request) == "function" and request)
    or (type(http_request) == "function" and http_request)
    or (type(syn) == "table" and type(syn.request) == "function" and syn.request)
    or (type(http) == "table" and type(http.request) == "function" and http.request)

local function startMonitor()
    if type(requestFn) ~= "function" then
        return false, "This executor does not expose a supported request function."
    end
    environment.CHLOE_MONITOR_CAPTURE_UI = true
    for port = 47821, 47830 do
        local ok, response = pcall(requestFn, {
            Url = string.format("http://127.0.0.1:%d/v1/client.lua", port),
            Method = "GET",
        })
        local status = ok and type(response) == "table" and tonumber(response.StatusCode or response.Status or response.status_code)
        local body = ok and type(response) == "table" and (response.Body or response.body)
        if status == 200 and type(body) == "string" and body ~= "" then
            local heartbeat, compileError = loadstring(body)
            if not heartbeat then return false, tostring(compileError) end
            task.spawn(heartbeat)
            local deadline = os.clock() + 5
            repeat task.wait(0.05) until type(environment.CHLOE_MONITOR_KEY) == "string" or os.clock() >= deadline
            if type(environment.CHLOE_MONITOR_KEY) ~= "string" then
                return false, "Monitor client started but no Secret-Key was generated."
            end
            if type(setclipboard) == "function" then pcall(setclipboard, environment.CHLOE_MONITOR_KEY) end
            return true, environment.CHLOE_MONITOR_KEY
        end
    end
    return false, "Open Chloe X Monitor first, then try again."
end

